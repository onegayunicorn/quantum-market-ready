# ============================================
# Quantum Market Ready App
# Environment Configuration
# ============================================

# Application
NODE_ENV=development
APP_NAME=quantum-market-ready
APP_VERSION=1.0.0
APP_URL=http://localhost:3000

# Server
PORT=3000
API_PORT=8080
WS_PORT=8081

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/quantum_db
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Quantum Engine
QUANTUM_ENGINE_URL=http://localhost:8080
QUANTUM_COHERENCE_THRESHOLD=0.9999
QUANTUM_MAX_QUBITS=128
QUANTUM_SIMULATION_MODE=hybrid

# AWS Configuration
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=quantum-market-assets
S3_REGION=ap-southeast-2

# GCP Configuration
GCP_PROJECT=sovereign-core-research
GCP_REGION=australia-southeast1

# Security
ENABLE_CORS=true
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1m

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_URL=http://localhost:3001
LOG_LEVEL=info

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@sovereigncore.research

# Market Data API
MARKET_DATA_API_KEY=
MARKET_DATA_WS_URL=wss://api.marketdata.com/v1/stream

# Feature Flags
ENABLE_QUANTUM_SIMULATION=true
ENABLE_REAL_TIME_QUOTES=true
ENABLE_ADVANCED_ANALYTICS=true